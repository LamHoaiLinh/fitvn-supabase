APP_ENV=development
APP_URL=http://localhost:3000
JWT_SECRET=doi_chuoi_bi_mat_dai_it_nhat_32_ky_tu
ADMIN_PASSWORD=doi_mat_khau_admin_khi_dev
ADMIN_PASSWORD_HASH=
ADMIN_NAME=admin-gia-dinh
MAX_ACTIVE_USERS=20

# Chọn backend dữ liệu: supabase | postgres | sheets
DATA_BACKEND=supabase

# Supabase/PostgreSQL database
# Lấy tại Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=
PGSSLMODE=require
PG_POOL_MAX=5

# Supabase Storage cho ảnh bài tập, không dùng service role ở frontend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_only_server
SUPABASE_EXERCISE_BUCKET=fitvn-exercise-images
EXERCISE_IMAGES_BASE_URL=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_optional

# Legacy fallback Google Sheets, chỉ cần khi DATA_BACKEND=sheets
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_KEY
-----END PRIVATE KEY-----
"
